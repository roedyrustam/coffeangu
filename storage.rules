rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Global Read Access (Required for sharing)
    match /{allPaths=**} {
      allow read: if true;
    }

    // Avatars: Only the user can upload their own profile picture
    match /avatars/{userId} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Shares: Authenticated users can upload shareable result images
    // We allow this because any user viewing a public result might trigger a screenshot generation
    match /shares/{sessionId} {
      allow write: if request.auth != null;
    }

    // Products: Only the user can upload images to their own product folder
    match /products/{userId}/{fileName} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
